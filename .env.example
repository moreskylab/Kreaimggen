# ─── App ───────────────────────────────────────────────────────────────────
APP_NAME=KreaImgGen
DEBUG=false

# ─── Security ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-a-strong-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ─── Broker / Backend ──────────────────────────────────────────────────────
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── Redis (rate-limit state) ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=kreaimggen
POSTGRES_PASSWORD=kreaimggen
POSTGRES_DB=kreaimggen
DATABASE_URL=postgresql+asyncpg://kreaimggen:kreaimggen@postgres:5432/kreaimggen
DATABASE_SYNC_URL=postgresql+psycopg2://kreaimggen:kreaimggen@postgres:5432/kreaimggen

# ─── Krea AI ───────────────────────────────────────────────────────────────
KREA_API_KEY=3620f8e6-091f-4c0f-b4b3-6bc53b8089cf:ixanjxfTmBbGdgLBNsV-d0mXZN1vEt5I
KREA_API_BASE_URL=https://api.krea.ai/v1
